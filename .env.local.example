# Google AdSense publisher ID — get from https://adsense.google.com
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX

# Supabase — Settings > API in your Supabase dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# Postgres direct connection — Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# Cron job protection — REQUIRED in production
# Must match the CRON_SECRET Vercel environment variable
CRON_SECRET=your-random-secret-minimum-32-characters

# Supabase anon key — for public read-only operations (Settings > API > anon/public)
# This is safe to use client-side; reserve SERVICE_ROLE_KEY for writes only
SUPABASE_ANON_KEY=your-anon-key-here
